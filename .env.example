# Server
PORT=8080
GIN_MODE=release

# PostgreSQL
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
DATABASE_URL=postgres://your_db_user:your_db_password@localhost:5433/pingmate?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# JWT
# Generate a strong random secret — never use a simple string in production
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRY_HOURS=72